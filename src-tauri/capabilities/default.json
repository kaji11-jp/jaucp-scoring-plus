{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "store:default",
      "allow": [
        { "path": "settings.json" },
        { "path": "history.json" }
      ]
    }
  ]
}